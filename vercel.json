{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "rewrites": [
    { 
      "source": "/embed", 
      "destination": "/src/components/embed/index.html" 
    },
    { 
      "source": "/((?!src/|assets/).*)", 
      "destination": "/" 
    }
  ]
}

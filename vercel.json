{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/embed",
      "destination": "/embed.html"
    },
    {
      "source": "/embed/(.*)",
      "destination": "/embed.html"
    },
    {
      "source": "/((?!src/|assets/).*)",
      "destination": "/index.html"
    }
  ]
}
